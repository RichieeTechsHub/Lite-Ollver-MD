{
  "name": "Lite-Ollver-MD",
  "description": "Lite-Ollver-MD WhatsApp bot for Heroku",
  "repository": "https://github.com/RichieeTechsHub/Lite-Ollver-MD",
  "logo": "https://raw.githubusercontent.com/RichieeTechsHub/Lite-Ollver-MD/main/assets/logo.png",
  "keywords": ["whatsapp", "baileys", "bot", "nodejs"],
  "env": {
    "SESSION_ID": {
      "description": "Paste your generated WhatsApp session ID",
      "required": true
    },
    "BOT_NAME": {
      "description": "Bot display name",
      "value": "Lite-Ollver-MD",
      "required": true
    },
    "OWNER_NAME": {
      "description": "Owner display name",
      "value": "RichiieeTheeGoat",
      "required": true
    },
    "OWNER_NUMBER": {
      "description": "Owner WhatsApp number in international format",
      "value": "254740479599",
      "required": true
    },
    "PREFIX": {
      "description": "Bot command prefix",
      "value": ".",
      "required": true
    },
    "MODE": {
      "description": "Bot mode",
      "value": "private",
      "required": true
    },
    "TIMEZONE": {
      "description": "Timezone",
      "value": "Africa/Nairobi",
      "required": true
    }
  },
  "formation": {
    "worker": {
      "quantity": 1,
      "size": "basic"
    }
  }
}
