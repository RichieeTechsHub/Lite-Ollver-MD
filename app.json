{
  "name": "Lite-Ollver-MD",
  "description": "WhatsApp Bot",
  "repository": "https://github.com/RichieeTechsHub/Lite-Ollver-MD",
  "logo": "https://raw.githubusercontent.com/RichieeTechsHub/Lite-Ollver-MD/main/assets/logo.png",
  "keywords": ["whatsapp", "bot", "baileys"],
  "env": {
    "BOT_NAME": {
      "description": "Your bot display name",
      "value": "Lite-Ollver-MD",
      "required": true
    },
    "SESSION_ID": {
      "description": "Your WhatsApp session ID",
      "required": true
    }
  },
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    }
  ],
  "formation": {
    "web": {
      "quantity": 1,
      "size": "basic"     // Changed from "eco" to "basic"
    },
    "worker": {
      "quantity": 1,
      "size": "basic"     // Changed from "eco" to "basic"
    }
  }
}
